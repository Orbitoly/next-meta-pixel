{
  "name": "next-meta-pixel",
  "version": "0.1.0",
  "description": "Facebook Pixel + Conversions API for Next.js App Router. Dual client/server tracking with automatic deduplication.",
  "license": "MIT",
  "author": "Orbitoly",
  "repository": {
    "type": "git",
    "url": "https://github.com/Orbitoly/next-meta-pixel"
  },
  "keywords": [
    "nextjs",
    "facebook",
    "meta",
    "pixel",
    "conversions-api",
    "capi",
    "tracking",
    "analytics",
    "facebook-pixel",
    "app-router",
    "react"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./handlers": {
      "types": "./dist/handlers.d.ts",
      "import": "./dist/handlers.js",
      "require": "./dist/handlers.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "server": [
        "./dist/server.d.ts"
      ],
      "handlers": [
        "./dist/handlers.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0"
  }
}
